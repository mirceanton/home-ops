{
  "version": 2,
  "uid": "bambuddy",
  "title": "Bambuddy",
  "timezone": "",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "30s",
  "editable": true,
  "tags": ["bambuddy", "3d-printing"],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "index": 1,
                  "text": "Disconnected"
                },
                "1": {
                  "color": "dark-green",
                  "index": 0,
                  "text": "Connected"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "dark-green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.3.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "bambuddy_printer_connected{printer_name=\"$printer\"}",
          "instant": true,
          "legendFormat": "Status",
          "refId": "A"
        }
      ],
      "title": "Connection",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": { "color": "grey", "index": 0, "text": "Unknown" },
                "1": { "color": "blue", "index": 1, "text": "Idle" },
                "2": { "color": "dark-green", "index": 2, "text": "Printing" },
                "3": { "color": "yellow", "index": 3, "text": "Paused" },
                "4": { "color": "teal", "index": 4, "text": "Finished" },
                "5": { "color": "red", "index": 5, "text": "Failed" },
                "6": { "color": "orange", "index": 6, "text": "Preparing" },
                "7": { "color": "purple", "index": 7, "text": "Slicing" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": 0 }]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
