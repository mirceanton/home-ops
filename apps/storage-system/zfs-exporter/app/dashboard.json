        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "zfs_pool_size_bytes{pool=~\"$pool\"}",
          "legendFormat": "{{ pool }}",
          "refId": "A"
        }
      ],
      "title": "Pool Size",
      "type": "stat"
    },
    {
      "datasource": {
