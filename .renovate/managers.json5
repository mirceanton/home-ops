{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "flux": {
    "managerFilePatterns": ["/\\.yaml(?:\\.j2)?$/"]
  },

  "helm-values": {
    "managerFilePatterns": ["/\\.yaml(?:\\.j2)?$/"]
  },

  "kubernetes": {
    "managerFilePatterns": ["/\\.yaml(?:\\.j2)?$/"]
  },

  "helmfile": {
    "managerFilePatterns": ["/helmfile\\.yaml$/"]
  },

  "mise": {
    "postUpgradeTasks": {
      "commands": ["mise install"],
      "fileFilters": ["mise.lock"],
      "executionMode": "branch"
    }
  }
}
